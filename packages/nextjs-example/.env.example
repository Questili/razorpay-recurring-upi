# Example app environment. Copy to .env and fill in real values.
# Use Razorpay TEST MODE keys only — never live keys in this example.
# Get them from https://dashboard.razorpay.com/app/keys (test mode tab).

# PostgreSQL connection string for the kit's billing tables.
# The schema lives in ./prisma/schema.prisma (re-exported from the prisma-adapter).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/india_recurring_billing?schema=public"

# Razorpay test-mode API credentials.
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Webhook secret from the Razorpay dashboard (Settings -> Webhooks).
# Used to verify the signature on POST /api/billing/webhook.
RAZORPAY_WEBHOOK_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# App-owned HMAC secret for upgrade/downgrade preview tokens.
# Generate with: openssl rand -base64 32
BILLING_PREVIEW_TOKEN_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
